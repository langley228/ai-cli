{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/protect-env.sh\"",
            "statusMessage": "檢查敏感檔案存取..."
          }
        ]
      }
    ]
  }
}
